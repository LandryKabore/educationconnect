{
  "name": "edufaso",
  "private": true,
  "version": "1.0.1",
  "description": "EduFaso — système de gestion scolaire",
  "author": "EduFaso",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "cross-env ELECTRON=true npm run build",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:multi": "wait-on http://localhost:5173 && concurrently -k \"cross-env VITE_DEV_SERVER_URL=http://localhost:5173 EDUFASO_INSTANCE=1 electron .\" \"cross-env VITE_DEV_SERVER_URL=http://localhost:5173 EDUFASO_INSTANCE=2 electron .\" \"cross-env VITE_DEV_SERVER_URL=http://localhost:5173 EDUFASO_INSTANCE=3 electron .\"",
    "electron:pack": "npm run build:electron && electron-builder --dir",
    "dist:win": "npm run build:electron && electron-builder --win nsis portable",
    "dist:mac": "npm run build:electron && electron-builder --mac dmg",
    "dist:desktop": "npm run build:electron && electron-builder --win nsis --mac dmg",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:add:android": "npx cap add android"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.8",
    "@capacitor/core": "^7.6.8",
    "@hookform/resolvers": "^5.4.0",
    "@supabase/supabase-js": "^2.110.6",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "i18next": "^26.3.6",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^17.0.9",
    "react-router-dom": "^7.18.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.8",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.4",
    "cross-env": "^7.0.3",
    "electron": "^37.10.3",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.9.3",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "bf.edufaso.desktop",
    "productName": "EduFaso",
    "compression": "maximum",
    "electronLanguages": [
      "fr",
      "en-US"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "EduFaso-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "EduFaso"
    },
    "portable": {
      "artifactName": "EduFaso-Portable-${version}.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "artifactName": "EduFaso-${version}-mac.${ext}",
      "category": "public.app-category.education"
    },
    "dmg": {
      "title": "EduFaso"
    },
    "publish": null
  }
}
